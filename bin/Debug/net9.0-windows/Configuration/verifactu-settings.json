{
  "$schema": "./verifactu-settings.schema.json",
  "_comment": "Configuración de VeriFactu - Valores por defecto",
  "IsProduction": false,
  "GenerarRegistrosEvento": false,
  // ✅ Configuración de depuración SOAP
  // ⚠️ IMPORTANTE: Cuando SaveDebugSoap = true:
  //    1. Los mensajes SOAP se guardan en archivos para depuración
  //    2. Las remisiones pendientes NO se persisten en BD (evita basura en desarrollo)
  //    3. Los errores se registran solo en logs (no en tabla VF_AeatRemisionesPendientes)
  "SaveDebugSoap": false,
  "DebugSoapFolder": null,  // null = usar Desktop del usuario
  "SimularErrorHuella": false,
  // Certificados (se configuran por entorno)
  "CertificadoThumbprint": "",
  "CertificadoRutaPfx": "",
  "CertificadoPassword": "",

  "Aeat": {
    "Endpoint": "https://prewww1.aeat.es:443/wlpl/TIKE-CONT/SistemaFacturacion",
    "SendTimeoutSeconds": 120,
    "ReceiveTimeoutSeconds": 120,
    "OpenTimeoutSeconds": 30,
    "CloseTimeoutSeconds": 30,
    "OperationTimeoutSeconds": 120,
    "ValidateServerCertificate": true,
    "RevocationMode": "Online",
    "TrustedStoreLocation": "LocalMachine",
    "RetryCount": 2,
    "RetryBaseDelayMilliseconds": 1000,
    "RetryBackoffFactor": 2.0
  },
  "Retry": {
    "MaxAttempts": 4,
    "PollingIntervalMinutes": 2,
    "Delays": {
      "FirstRetryMinutes": 5,
      "SecondRetryMinutes": 15,
      "ThirdRetryMinutes": 30,
      "FourthRetryMinutes": 60,
      "MaxDelayHours": 6,
      "BackoffFactor": 2.0
    }
  },
  "XmlSchemaVersion": "1.0",
  "SystemVersion": "1.0.0",
  "Qr": {
    "Environment": 1
  },
  "SignaturePolicy": {
    "Oid": "",
    "Url": "",
    "PolicyHashBase64": "",
    "HashAlgorithm": "SHA1"
  }
}
